{
  "app_id": "prism-ocr",
  "name": "ZCLUM Prism OCR",
  "display_name": "ZCLUM Prism OCR",
  "description": "Open-source PDF OCR to Markdown and RAG document-intelligence agent, ready for zclum.com integration.",
  "homepage": "https://zclum.com",
  "base_url_placeholder": "${OCR_HARNESS_BASE_URL}",
  "not_configured_error": {
    "status": 503,
    "code": "ocr_harness_not_configured",
    "message": "OCR-Harness base URL is not configured."
  },
  "required_env": [
    {
      "name": "OCR_HARNESS_BASE_URL",
      "description": "FastAPI base URL, for example https://api.zclum.com/ocr-harness or http://127.0.0.1:8080",
      "required": true
    },
    {
      "name": "OCR_HARNESS_MAX_UPLOAD_MB",
      "description": "Gateway upload limit in MB.",
      "required": false,
      "default": "200"
    },
    {
      "name": "OCR_HARNESS_TIMEOUT_SECONDS",
      "description": "Gateway timeout for OCR and RAG requests.",
      "required": false,
      "default": "600"
    }
  ],
  "routes": [
    { "id": "health", "method": "GET", "path": "/api/health", "gateway_path": "/api/agents/ocr-harness/health", "auth": "public", "description": "Health check." },
    { "id": "engines", "method": "GET", "path": "/api/engines", "gateway_path": "/api/agents/ocr-harness/engines", "auth": "user", "description": "List OCR engines and availability." },
    { "id": "convert_pdf", "method": "POST", "path": "/api/convert", "gateway_path": "/api/agents/ocr-harness/convert", "content_type": "multipart/form-data", "auth": "user", "description": "Upload PDF and start OCR conversion." },
    { "id": "task_status", "method": "GET", "path": "/api/status/{task_id}", "gateway_path": "/api/agents/ocr-harness/status/{task_id}", "auth": "user", "description": "Poll OCR task status." },
    { "id": "task_result", "method": "GET", "path": "/api/result/{task_id}", "gateway_path": "/api/agents/ocr-harness/result/{task_id}", "auth": "user", "description": "Get OCR result and quality score." },
    { "id": "download_markdown", "method": "GET", "path": "/api/download/{task_id}", "gateway_path": "/api/agents/ocr-harness/download/{task_id}", "auth": "user", "description": "Download Markdown output." },
    { "id": "format_markdown", "method": "POST", "path": "/api/format/markdown", "gateway_path": "/api/agents/ocr-harness/format/markdown", "content_type": "application/json", "auth": "user", "description": "Clean and refine Markdown." },
    { "id": "rag_status", "method": "GET", "path": "/api/rag/status", "gateway_path": "/api/agents/ocr-harness/rag/status", "auth": "user", "description": "Get RAG index status." },
    { "id": "rag_query", "method": "POST", "path": "/api/rag/query", "gateway_path": "/api/agents/ocr-harness/rag/query", "content_type": "application/json", "auth": "user", "description": "Ask RAG question and return references." },
    { "id": "providers_list", "method": "GET", "path": "/api/providers", "gateway_path": "/api/agents/ocr-harness/providers", "auth": "admin", "description": "List configured LLM providers." },
    { "id": "kb_sources", "method": "GET", "path": "/api/kb-sources", "gateway_path": "/api/agents/ocr-harness/kb-sources", "auth": "admin", "description": "List mounted knowledge sources." }
  ],
  "frontend_cards": [
    { "id": "upload_pdf", "title": "Upload PDF", "description": "Start OCR to Markdown.", "route_id": "convert_pdf", "primary": true },
    { "id": "markdown_result", "title": "Markdown Result", "description": "View extracted Markdown and download it.", "route_id": "task_result" },
    { "id": "quality_score", "title": "Quality Score", "description": "Review OCR quality and engine routing.", "route_id": "task_result" },
    { "id": "rag_query", "title": "Knowledge Search", "description": "Ask questions against the indexed corpus.", "route_id": "rag_query" },
    { "id": "format_markdown", "title": "Format Markdown", "description": "Clean OCR Markdown before export or indexing.", "route_id": "format_markdown" },
    { "id": "provider_settings", "title": "Model Settings", "description": "Configure LLM providers.", "route_id": "providers_list", "admin_only": true }
  ],
  "gateway_proxy": {
    "strip_prefix": "/api/agents/ocr-harness",
    "add_prefix": "/api",
    "stream_uploads": true,
    "timeout_seconds": 600,
    "max_upload_mb": 200,
    "when_unconfigured": "return ocr_harness_not_configured"
  }
}
