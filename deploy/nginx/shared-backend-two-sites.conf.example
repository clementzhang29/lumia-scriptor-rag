upstream ocr_harness_backend {
    server 47.96.7.204:8080;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    server_name zclum.com www.zclum.com;

    ssl_certificate /etc/letsencrypt/live/zclum.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/zclum.com/privkey.pem;

    client_max_body_size 200m;

    location /api/agents/ocr-harness/ {
        rewrite ^/api/agents/ocr-harness/(.*)$ /api/$1 break;
        proxy_pass http://ocr_harness_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
}

server {
    listen 443 ssl http2;
    server_name second-site.example.com www.second-site.example.com;

    ssl_certificate /etc/letsencrypt/live/second-site.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/second-site.example.com/privkey.pem;

    client_max_body_size 200m;

    location /api/agents/ocr-harness/ {
        rewrite ^/api/agents/ocr-harness/(.*)$ /api/$1 break;
        proxy_pass http://ocr_harness_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
}
